# ─── Copier ce fichier en .env et remplir les valeurs ───────────────────────
# Railway injecte automatiquement DATABASE_URL en production.
# En local, laisser vide = SQLite dans data/biblioth.db

DATABASE_URL=

# ─── Clé API pour les fonctions generate_* (Mode 1, 2, 3) ──────────────────
# Décommentez et renseignez la clé correspondant à votre fournisseur IA :
#   Perplexity :  https://www.perplexity.ai/settings/api
#   Anthropic  :  https://console.anthropic.com/
#   OpenAI     :  https://platform.openai.com/api-keys

# AI_API_KEY=votre_cle_ici
# AI_PROVIDER=perplexity   # perplexity | anthropic | openai
